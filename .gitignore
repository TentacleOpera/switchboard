# Dependencies
node_modules/
yarn.lock
package-lock.json

# Build output
out/
dist/

# Packaged extensions
*.vsix

# Release staging folder (prebuilt .vsix artifacts; ignored to keep release assets out of git history)
releases/

# Local env / secrets — never commit
.env
.env.*

# TypeScript cache
*.tsbuildinfo

# IDE
.idea/

# OS files
.DS_Store
Icon
Thumbs.db

# Test output
.vscode-test/

# Logs
*.log
npm-debug.log*

# Temp/patch files
*.patch
*.tmp
diff_output.txt
list_output.txt

# Test artifacts (generated by test suite)
.test-workspace/
.tmp-codex-home/

.web-ai/

# >>> Switchboard managed exclusions >>>
# Switchboard runtime state (per-session, not shareable)
.switchboard/*
!.switchboard/reviews/
!.switchboard/plans/
!.switchboard/features/
!.switchboard/sessions/
!.switchboard/CLIENT_CONFIG.md
!.switchboard/README.md
!.switchboard/SWITCHBOARD_PROTOCOL.md

# Notion page content cache
.switchboard/notion-cache.md

# kanban.db is machine-local state that differs per developer — never commit it.
# The recursive globs also block a stray SQLite DB accidentally created in a
# subdir (e.g. plans/ or features/) when sqlite3 is run from the wrong cwd.
.switchboard/kanban.db
.switchboard/**/*.db
.switchboard/**/*.db-shm
.switchboard/**/*.db-wal
# <<< Switchboard managed exclusions <<<
