{
  "mcpServers": {
    "switchboard": {
      "command": "node",
      "args": [
        "./.switchboard/MCP/mcp-server.js",
        "."
      ],
      "env": {
        "SWITCHBOARD_WORKSPACE_ROOT": ".",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      }
    }
  },
  "servers": {
    "switchboard": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/.switchboard/MCP/mcp-server.js"
      ],
      "env": {
        "SWITCHBOARD_WORKSPACE_ROOT": "/Users/patrickvuleta/Documents/GitHub/switchboard",
        "SWITCHBOARD_STATE_ROOT": "/Users/patrickvuleta/Documents/GitHub/switchboard"
      }
    }
  }
}